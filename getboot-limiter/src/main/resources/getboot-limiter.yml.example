getboot:
  limiter:
    enabled: true
    sliding-window:
      enabled: true
      default-timeout: 5
      key-prefix: rate_limiter
      limiters:
        create-order:
          rate: 20
          interval: 1
          interval-unit: SECONDS
    token-bucket:
      enabled: true
      default-timeout: 2
      key-prefix: rate_limiter_token_bucket
      limiters:
        send-sms:
          rate: 30
          interval: 1
          interval-unit: SECONDS
    leaky-bucket:
      enabled: true
      default-timeout: 3
      key-prefix: rate_limiter_leaky_bucket
      limiters:
        callback:
          rate: 10
          interval: 1
          interval-unit: SECONDS
