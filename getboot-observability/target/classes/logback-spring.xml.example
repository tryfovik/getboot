<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 控制台日志输出，统一打印 tid 与 SkyWalking TraceId -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [tid:%X{traceId}] [swTid:%X{skywalkingTraceId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
